<div class="search-blog-container">
    <div class="search-header">
        <h2 class="search-title">🔍 Busca tus artículos</h2>
        <p class="search-subtitle">Encuentra contenido que te interesa</p>
    </div>
    
    <div class="search-wrapper">
        <div class="search-input-group">
            <svg class="search-icon-left" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
            </svg>
            <input 
                type="text" 
                id="blog-search-input" 
                class="search-input" 
                placeholder="Escribe para buscar..."
                aria-label="Buscar artículos del blog"
            >
            <button id="clear-search-btn" class="search-clear-icon" style="display: none;" aria-label="Limpiar búsqueda">
                ✕
            </button>
        </div>
        <button id="search-btn" class="search-btn" aria-label="Realizar búsqueda">
            <span>Buscar</span>
        </button>
    </div>
    
    <div id="search-results" class="search-results" style="display: none;"></div>
</div>
