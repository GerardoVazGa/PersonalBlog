<%- include('partials/header.ejs') %>
<main class="main-content">
    <section id="create-post">
        <div class="create-post-container">
            <div class="breadcrumb">
                <a href="/">← Volver al inicio</a>
            </div>
            <h1 class="create-post-title">Crear Nueva Publicación</h1>
            <form id="create-post-form" class="form-inputs" enctype="multipart/form-data">
                <div class="form-group">
                    <label for="title">Título</label>
                    <input type="text" id="title" name="title" required>
                </div>
                <div class="form-group">
                    <label for="image">Imagen</label>
                    <label for="post-image" class="file-input-label">
                        📁 Seleccionar imagen
                    </label>
                    <input type="file" id="post-image" name="image" accept="image/*">
                    <img id="current-image" class="current-image"
                        src=""
                        alt="Imagen de portada">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="category">Categoría</label>
                        <select id="category" name="category" required>
                            <option value="">Seleccionar categoría</option>
                            <% formCategories.forEach(category=> { %>
                                <option value="<%= category.name %>">
                                    <%= category.name %>
                                </option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="post-tags">Etiquetas (separadas por |)</label>
                        <input type="text" id="post-tags" name="tags" placeholder="ej: tag1|tag2|tag3" required>
                    </div>
                </div>
                <div class="form-group">
                    <label for="content">Contenido</label>
                    <div id="post-content-editor" name="content" ></div>
                    <input 
                        type="hidden" 
                        id="post-content" 
                        name="content"
                    >
                </div>
                <div class="form-actions">
                    <button id="btn-save-edit" type="button" class="btn btn-submit">Guardar Cambios</button>
                    <button id="btn-cancel-edit" type="button" class="btn btn-cancel">Cancelar</button>
                </div>
            </form>
        </div>
    </section>
</main>

<%- include('partials/scripts.ejs') %>
